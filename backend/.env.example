GOOGLE_API_KEY=your_api_key_here

# Prompt Caching Configuration
# Enable/disable Gemini API prompt caching
NAVIBOT_CACHE_ENABLED=true

# Cache TTL in minutes (default: 60)
# Recommended: 30-120 minutes based on session duration
NAVIBOT_CACHE_TTL_MINUTES=60

# Model to use for cached content
# Note: Must be a model that supports caching (gemini-1.5-flash-001, etc.)
NAVIBOT_CACHE_MODEL=gemini-1.5-flash-001

# Cache version - bump this to invalidate all existing caches
# Format: semver string (e.g., "1.0.0")
NAVIBOT_CACHE_VERSION=1.0.0

# Conversation Summarizer Configuration
# Threshold: Number of messages before summarization triggers (default: 10)
NAVIBOT_SUMMARIZER_THRESHOLD=10

# Compression level: low, medium, or high (default: medium)
NAVIBOT_SUMMARIZER_LEVEL=medium

# Number of recent messages to keep after summarization (default: 3)
NAVIBOT_SUMMARIZER_KEEP_RECENT=3

# Model to use for summarization (default: gemini-1.5-flash-001)
NAVIBOT_SUMMARIZER_MODEL=gemini-1.5-flash-001
