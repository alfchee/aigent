{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "e2e:ci": "cross-env VITE_ENABLE_MOCK_WS=1 start-server-and-test dev http://localhost:5173 e2e:run",
    "prepare": "cd .. && node frontend/node_modules/husky/bin.js install .husky"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "dompurify": "^3.2.6",
    "idb": "^8.0.2",
    "lucide-vue-next": "^0.511.0",
    "pinia": "^2.3.1",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "cross-env": "^7.0.3",
    "cypress": "^14.5.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.20.1",
    "fake-indexeddb": "^6.0.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.1",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.35",
    "prettier": "^3.6.2",
    "start-server-and-test": "^2.0.12",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.0.12",
    "vite-plugin-pwa": "^0.21.2",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^1.8.27"
  },
  "lint-staged": {
    "*.{ts,vue,js,css,md,json,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,vue}": [
      "eslint --fix"
    ]
  }
}
